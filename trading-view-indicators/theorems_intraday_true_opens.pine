//@version=6
indicator("Theorems Intraday True Opens", overlay=true)

// ================= TIMEFRAME FILTER =================
show_M1  = input.bool(false, "Show on 1 Minute")
show_M5  = input.bool(true, "Show on 5 Minute")
show_M15 = input.bool(true, "Show on 15 Minute")
show_M30 = input.bool(false, "Show on 30 Minute")
show_H1  = input.bool(true, "Show on 1 Hour")
show_H4  = input.bool(false, "Show on 4 Hour")
show_D1  = input.bool(false, "Show on Daily")
show_W1  = input.bool(false, "Show on Weekly")
show_MN1 = input.bool(false, "Show on Monthly")

isTfAllowed() =>
    tf = timeframe.period
    result = switch tf
        "1"   => show_M1
        "5"   => show_M5
        "15"  => show_M15
        "30"  => show_M30
        "60"  => show_H1
        "240" => show_H4
        "D"   => show_D1
        "W"   => show_W1
        "M"   => show_MN1
        => false
    result

// ================= GLOBAL INPUTS =================
useServerTime = input.bool(true, "Use Server Time")
daysBack = input.int(20, "Days Back", minval=1, maxval=100)
onlyToday = input.bool(false, "Only Today")

// ================= DAILY LINES =================
// Line 1
l1_enable = input.bool(true, "Line 1 Enable", group="Line 1")
l1_hour = input.int(8, "Hour", minval=0, maxval=23, group="Line 1")
l1_minute = input.int(0, "Minute", minval=0, maxval=59, group="Line 1")
l1_fullDay = input.bool(false, "Full Day", group="Line 1")
l1_lengthMinutes = input.int(120, "Length (Minutes)", minval=1, group="Line 1")
l1_color = input.color(color.rgb(0, 191, 255), "Color", group="Line 1")
l1_width = input.int(2, "Width", minval=1, maxval=5, group="Line 1")
l1_style = input.string("Solid", "Style", options=["Solid", "Dashed", "Dotted"], group="Line 1")

// Line 2
l2_enable = input.bool(false, "Line 2 Enable", group="Line 2")
l2_hour = input.int(9, "Hour", minval=0, maxval=23, group="Line 2")
l2_minute = input.int(0, "Minute", minval=0, maxval=59, group="Line 2")
l2_fullDay = input.bool(false, "Full Day", group="Line 2")
l2_lengthMinutes = input.int(120, "Length (Minutes)", minval=1, group="Line 2")
l2_color = input.color(color.orange, "Color", group="Line 2")
l2_width = input.int(2, "Width", minval=1, maxval=5, group="Line 2")
l2_style = input.string("Solid", "Style", options=["Solid", "Dashed", "Dotted"], group="Line 2")

// Line 3
l3_enable = input.bool(false, "Line 3 Enable", group="Line 3")
l3_hour = input.int(10, "Hour", minval=0, maxval=23, group="Line 3")
l3_minute = input.int(0, "Minute", minval=0, maxval=59, group="Line 3")
l3_fullDay = input.bool(false, "Full Day", group="Line 3")
l3_lengthMinutes = input.int(120, "Length (Minutes)", minval=1, group="Line 3")
l3_color = input.color(color.lime, "Color", group="Line 3")
l3_width = input.int(2, "Width", minval=1, maxval=5, group="Line 3")
l3_style = input.string("Solid", "Style", options=["Solid", "Dashed", "Dotted"], group="Line 3")

// Line 4
l4_enable = input.bool(false, "Line 4 Enable", group="Line 4")
l4_hour = input.int(11, "Hour", minval=0, maxval=23, group="Line 4")
l4_minute = input.int(0, "Minute", minval=0, maxval=59, group="Line 4")
l4_fullDay = input.bool(false, "Full Day", group="Line 4")
l4_lengthMinutes = input.int(120, "Length (Minutes)", minval=1, group="Line 4")
l4_color = input.color(color.fuchsia, "Color", group="Line 4")
l4_width = input.int(2, "Width", minval=1, maxval=5, group="Line 4")
l4_style = input.string("Solid", "Style", options=["Solid", "Dashed", "Dotted"], group="Line 4")

// Line 5
l5_enable = input.bool(false, "Line 5 Enable", group="Line 5")
l5_hour = input.int(12, "Hour", minval=0, maxval=23, group="Line 5")
l5_minute = input.int(0, "Minute", minval=0, maxval=59, group="Line 5")
l5_fullDay = input.bool(false, "Full Day", group="Line 5")
l5_lengthMinutes = input.int(120, "Length (Minutes)", minval=1, group="Line 5")
l5_color = input.color(color.red, "Color", group="Line 5")
l5_width = input.int(2, "Width", minval=1, maxval=5, group="Line 5")
l5_style = input.string("Solid", "Style", options=["Solid", "Dashed", "Dotted"], group="Line 5")

// Helper function to convert style string to line.style
getLineStyle(styleStr) =>
    switch styleStr
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

// Function to draw lines for a specific time
drawLineForDay(enable, hour, minute, fullDay, lengthMinutes, lineColor, lineWidth, lineStyle, dayOffset) =>
    if enable and isTfAllowed()
        // Calculate target time
        targetTime = timestamp(year(time), month(time), dayofmonth(time) - dayOffset, hour, minute, 0)

        // Get the open price at target time
        openPrice = request.security(syminfo.tickerid, timeframe.period, open[math.max(0, bar_index - ta.barssince(time == targetTime))])

        // Calculate end time
        endTime = fullDay ? targetTime + (24 * 60 * 60 * 1000) : targetTime + (lengthMinutes * 60 * 1000)

        // Draw the line only if we have valid data
        if not na(openPrice) and targetTime <= time
            // Find bar index for target time
            targetBarIndex = math.max(0, ta.barssince(time >= targetTime))
            // Calculate end bar index based on duration
            durationBars = math.max(1, math.round((endTime - targetTime) / (timeframe.in_seconds(timeframe.period) * 1000)))
            endBarIndex = math.max(targetBarIndex, bar_index - targetBarIndex + durationBars)

            line.new(bar_index - targetBarIndex, openPrice, endBarIndex, openPrice,
                color=lineColor, width=lineWidth, style=getLineStyle(lineStyle))

// Main execution
if barstate.islast
    // Delete all previous lines
    for lineObj in line.all
        line.delete(lineObj)

    // Determine number of days to draw
    numDays = onlyToday ? 1 : daysBack

    // Draw lines for each day
    for dayOffset = 0 to numDays - 1
        drawLineForDay(l1_enable, l1_hour, l1_minute, l1_fullDay, l1_lengthMinutes, l1_color, l1_width, l1_style, dayOffset)
        drawLineForDay(l2_enable, l2_hour, l2_minute, l2_fullDay, l2_lengthMinutes, l2_color, l2_width, l2_style, dayOffset)
        drawLineForDay(l3_enable, l3_hour, l3_minute, l3_fullDay, l3_lengthMinutes, l3_color, l3_width, l3_style, dayOffset)
        drawLineForDay(l4_enable, l4_hour, l4_minute, l4_fullDay, l4_lengthMinutes, l4_color, l4_width, l4_style, dayOffset)
        drawLineForDay(l5_enable, l5_hour, l5_minute, l5_fullDay, l5_lengthMinutes, l5_color, l5_width, l5_style, dayOffset)