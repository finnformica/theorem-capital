//@version=6
indicator("Theorems Sessions Bottom Pane", "Sessions Timeline", overlay=false, max_boxes_count=500, max_labels_count=500)

// === CONFIGURATION ===
// Display settings
show_labels = input.bool(true, "Show Session Labels", group="Display")
label_size = input.string("small", "Label Size", options=["tiny", "small", "normal"], group="Display")
max_history_bars = input.int(200, "Maximum History Bars", minval=50, maxval=500, group="Display")

// Layer enables
enable_day = input.bool(true, "Enable Day Sessions", group="Layers")
enable_week = input.bool(true, "Enable Week Sessions", group="Layers")
enable_month = input.bool(true, "Enable Month Sessions", group="Layers")

// Session Colors
color_q1 = input.color(color.new(#708090, 50), "Quarter 1 Color", group="Colors")
color_q2 = input.color(color.new(#800000, 50), "Quarter 2 Color", group="Colors")
color_q3 = input.color(color.new(#006400, 50), "Quarter 3 Color", group="Colors")
color_q4 = input.color(color.new(#191970, 50), "Quarter 4 Color", group="Colors")

// Day Session Times (fixed for all markets)
day_session1_start = input.int(0, "Day Q1 Start Hour", minval=0, maxval=23, group="Day Sessions")
day_session2_start = input.int(6, "Day Q2 Start Hour", minval=0, maxval=23, group="Day Sessions")
day_session3_start = input.int(12, "Day Q3 Start Hour", minval=0, maxval=23, group="Day Sessions")
day_session4_start = input.int(18, "Day Q4 Start Hour", minval=0, maxval=23, group="Day Sessions")

// === STATE TRACKING ===
// We need to track session states properly
var int lastDaySession = -1
var int lastWeekSession = -1
var int lastMonthSession = -1

// Track box references for each session
var box dayBox = na
var box weekBox = na
var box monthBox = na

// Track when sessions started
var int daySessionStartBar = na
var int weekSessionStartBar = na
var int monthSessionStartBar = na

// Arrays for cleanup
var box[] allBoxes = array.new<box>()
var label[] allLabels = array.new<label>()

// === FUNCTIONS ===

// Get day quarter (0-3) based on hour
getDayQuarter(h) =>
    if h >= day_session4_start or h < day_session1_start
        3  // Q4: Evening/Night
    else if h >= day_session3_start
        2  // Q3: Afternoon
    else if h >= day_session2_start
        1  // Q2: Morning
    else
        0  // Q1: Early Morning

// Get week quarter (0-3)
// Trading week perspective: Sunday 18:00 to Friday 17:00 (NYC time)
getWeekQuarter(currentTime) =>
    dow = dayofweek(currentTime)
    h = hour(currentTime)

    // Simple approach: divide the trading week into quarters
    // Q1: Sun 18:00 - Tue 06:00
    // Q2: Tue 06:00 - Wed 18:00
    // Q3: Wed 18:00 - Fri 06:00
    // Q4: Fri 06:00 - Sun 18:00 (includes weekend)

    quarter = 0
    if dow == 1  // Sunday
        quarter := h >= 18 ? 0 : 3
    else if dow == 2  // Monday
        quarter := 0
    else if dow == 3  // Tuesday
        quarter := h < 6 ? 0 : 1
    else if dow == 4  // Wednesday
        quarter := h < 18 ? 1 : 2
    else if dow == 5  // Thursday
        quarter := 2
    else if dow == 6  // Friday
        quarter := h < 6 ? 2 : 3
    else if dow == 7  // Saturday
        quarter := 3

    quarter

// Get month quarter (0-3) based on week of month
// More accurate calculation based on actual week boundaries
getMonthQuarter(currentTime) =>
    dom = dayofmonth(currentTime)

    // Calculate which week of the month we're in (0-based)
    // Week 1: Days 1-7, Week 2: Days 8-14, Week 3: Days 15-21, Week 4: Days 22+
    weekOfMonth = 0
    if dom >= 22
        weekOfMonth := 3  // Week 4+
    else if dom >= 15
        weekOfMonth := 2  // Week 3
    else if dom >= 8
        weekOfMonth := 1  // Week 2
    else
        weekOfMonth := 0  // Week 1

    weekOfMonth

// Get color for quarter
getQuarterColor(quarter) =>
    switch quarter
        0 => color_q1
        1 => color_q2
        2 => color_q3
        3 => color_q4
        => color.gray

// Get label text
getLabelText(prefix, quarter) =>
    prefix + "-Q" + str.tostring(quarter + 1)

// Get label size
getLabelSize() =>
    switch label_size
        "tiny" => size.tiny
        "small" => size.small
        "normal" => size.normal
        => size.small

// === LAYER POSITIONING ===
layer_height = 30
base_y = 5
month_y = base_y  // Bottom layer
week_y = base_y + layer_height  // Middle layer
day_y = base_y + layer_height * 2  // Top layer

// === MAIN LOGIC ===

// Get current time components
currentHour = hour(time)
currentTime = time

// Calculate current sessions
currentDaySession = getDayQuarter(currentHour)
currentWeekSession = getWeekQuarter(currentTime)
currentMonthSession = getMonthQuarter(currentTime)

// === DAY SESSION HANDLING ===
if enable_day
    // Check if day session changed
    if currentDaySession != lastDaySession
        // Finish previous box
        if not na(dayBox)
            box.set_right(dayBox, bar_index)

        // Create new box
        daySessionStartBar := bar_index
        dayBox := box.new(
            left=bar_index,
            top=day_y + layer_height,
            right=bar_index + 1,
            bottom=day_y,
            bgcolor=getQuarterColor(currentDaySession),
            border_color=color.new(color.gray, 80),
            border_width=1
        )
        array.push(allBoxes, dayBox)

        // Add label
        if show_labels
            lbl = label.new(
                x=bar_index,
                y=day_y + layer_height/2,
                text=getLabelText("D", currentDaySession),
                style=label.style_label_left,
                color=color.new(color.black, 100),
                textcolor=color.white,
                size=getLabelSize()
            )
            array.push(allLabels, lbl)

        lastDaySession := currentDaySession
    else
        // Extend current box
        if not na(dayBox)
            box.set_right(dayBox, bar_index + 1)

// === WEEK SESSION HANDLING ===
if enable_week
    // Check if week session changed
    if currentWeekSession != lastWeekSession
        // Finish previous box
        if not na(weekBox)
            box.set_right(weekBox, bar_index)

        // Create new box
        weekSessionStartBar := bar_index
        weekBox := box.new(
            left=bar_index,
            top=week_y + layer_height,
            right=bar_index + 1,
            bottom=week_y,
            bgcolor=getQuarterColor(currentWeekSession),
            border_color=color.new(color.gray, 80),
            border_width=1
        )
        array.push(allBoxes, weekBox)

        // Add label
        if show_labels
            lbl = label.new(
                x=bar_index,
                y=week_y + layer_height/2,
                text=getLabelText("W", currentWeekSession),
                style=label.style_label_left,
                color=color.new(color.black, 100),
                textcolor=color.white,
                size=getLabelSize()
            )
            array.push(allLabels, lbl)

        lastWeekSession := currentWeekSession
    else
        // Extend current box
        if not na(weekBox)
            box.set_right(weekBox, bar_index + 1)

// === MONTH SESSION HANDLING ===
if enable_month
    // Check if month session changed
    if currentMonthSession != lastMonthSession
        // Finish previous box
        if not na(monthBox)
            box.set_right(monthBox, bar_index)

        // Create new box
        monthSessionStartBar := bar_index
        monthBox := box.new(
            left=bar_index,
            top=month_y + layer_height,
            right=bar_index + 1,
            bottom=month_y,
            bgcolor=getQuarterColor(currentMonthSession),
            border_color=color.new(color.gray, 80),
            border_width=1
        )
        array.push(allBoxes, monthBox)

        // Add label
        if show_labels
            lbl = label.new(
                x=bar_index,
                y=month_y + layer_height/2,
                text=getLabelText("M", currentMonthSession),
                style=label.style_label_left,
                color=color.new(color.black, 100),
                textcolor=color.white,
                size=getLabelSize()
            )
            array.push(allLabels, lbl)

        lastMonthSession := currentMonthSession
    else
        // Extend current box
        if not na(monthBox)
            box.set_right(monthBox, bar_index + 1)

// === CLEANUP ===
// Remove old boxes beyond history limit
if barstate.islast
    // Clean up boxes
    while array.size(allBoxes) > 50
        oldBox = array.shift(allBoxes)
        if not na(oldBox)
            box.delete(oldBox)

    // Clean up labels
    while array.size(allLabels) > 50
        oldLabel = array.shift(allLabels)
        if not na(oldLabel)
            label.delete(oldLabel)

// === VISUAL GUIDES ===
hline(day_y + layer_height * 1.5, "", color=color.new(color.gray, 95), linestyle=hline.style_dotted)
hline(week_y + layer_height * 0.5, "", color=color.new(color.gray, 95), linestyle=hline.style_dotted)
hline(month_y, "", color=color.new(color.gray, 95), linestyle=hline.style_dotted)

// Invisible plot to maintain scale
plot(50, "", color.new(color.white, 100), display=display.none)