//@version=6
indicator("Theorems Sessions", "Sessions", overlay=false, max_boxes_count=500, max_labels_count=500)

// === CONFIGURATION ===
show_labels = input.bool(true, "Show Session Labels", group="Display")
label_size = input.string("small", "Label Size", options=["tiny", "small", "normal"], group="Display")

// Master timing configuration - all cycles inherit from this single point
master_start_dow = input.int(2, "Master Start Day of Week", minval=0, maxval=6, group="Master Timing", tooltip="0=Sunday, 1=Monday, 2=Tuesday, 3=Wednesday, 4=Thursday, 5=Friday, 6=Saturday")
master_start_hour = input.int(21, "Master Start Hour", minval=0, maxval=23, group="Master Timing", tooltip="Hour in 24h format (0-23)")
master_start_minute = input.int(15, "Master Start Minute", minval=0, maxval=59, group="Master Timing")

// Timeframe visibility settings (comma-separated list of timeframes)
year_timeframes = input.string("H4,H1", "Year Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,1D,1W,1M")
month_timeframes = input.string("H4,H1", "Month Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,1D,1W,1M")
week_timeframes = input.string("H4,H1,M15", "Week Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,1D,1W,1M")
day_timeframes = input.string("M15,M5,M1", "Day Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,1D,1W,1M")
hour6_timeframes = input.string("M5,M1", "6-Hour Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,1D,1W,1M")
min90_timeframes = input.string("M1", "90-Min Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,1D,1W,1M")

// Universal Quarter Colors
q1_color = input.color(color.new(color.gray, 80), "Quarter 1 Color", group="Colors")
q2_color = input.color(color.new(color.red, 80), "Quarter 2 Color", group="Colors")
q3_color = input.color(color.new(color.green, 80), "Quarter 3 Color", group="Colors")
q4_color = input.color(color.new(color.blue, 80), "Quarter 4 Color", group="Colors")

// Session type indices
YEAR_SESSION = 0
MONTH_SESSION = 1
WEEK_SESSION = 2
DAY_SESSION = 3
HOUR6_SESSION = 4
MIN90_SESSION = 5

// === CYCLE CONSTANTS ===
MS_PER_MINUTE = 60 * 1000
CYCLE_90M_MS = 90 * MS_PER_MINUTE
MAX_VISIBLE_CYCLES = 50

// === GENERIC HELPERS ===

f_tf_enabled(tf_list) =>
    tf = timeframe.period
    current_label = switch tf
        "1"   => "M1"
        "3"   => "M3"
        "5"   => "M5"
        "15"  => "M15"
        "30"  => "M30"
        "45"  => "M45"
        "60"  => "H1"
        "120" => "H2"
        "240" => "H4"
        "D"   => "1D"
        "1D"  => "1D"
        "W"   => "1W"
        "1W"  => "1W"
        "M"   => "1M"
        "1M"  => "1M"
        => tf
    clean_list = str.replace_all(tf_list, " ", "")
    str.contains("," + clean_list + ",", "," + current_label + ",")

// Master anchor: computed synthetically — the most recent past occurrence of
// (master DOW + master hour + master minute) at or before the first processed bar.
// This does NOT require a real bar to exist at that time (avoids data-gap issues
// on symbols that don't tick through weekend/session boundaries). Pine's dayofweek
// is 1-7 (Sun=1); master input is 0-6 (Sun=0), so target_dow = master + 1.
var int anchor = na
if na(anchor)
    target_dow_pine = master_start_dow + 1
    day_diff        = (dayofweek - target_dow_pine + 7) % 7
    target_date_ms  = time - day_diff * 24 * 60 * 60 * 1000
    candidate = timestamp(syminfo.timezone, year(target_date_ms), month(target_date_ms), dayofmonth(target_date_ms), master_start_hour, master_start_minute)
    // If target hour/minute is later in the day than the current bar, candidate is in the
    // future → step back one week to guarantee anchor is in the past.
    anchor := candidate > time ? candidate - 7 * 24 * 60 * 60 * 1000 : candidate

f_cycle_math(t, a, cycle_ms) =>
    cycle_idx = math.floor((t - a) / cycle_ms)
    cycle_start = a + cycle_idx * cycle_ms
    quarter_ms = math.floor(cycle_ms / 4.0)
    quarter_idx = math.floor((t - cycle_start) / quarter_ms)
    [cycle_start, quarter_idx]

f_quarter_color(q_idx) =>
    q_idx == 0 ? q1_color : q_idx == 1 ? q2_color : q_idx == 2 ? q3_color : q4_color

f_label_size() =>
    label_size == "tiny" ? size.tiny : label_size == "normal" ? size.normal : size.small

// === GENERIC RENDERER ===
f_render_cycle(cycle_ms, y_bot, y_top, tf_list, label_prefix, boxes_arr, labels_arr) =>
    if barstate.islast and f_tf_enabled(tf_list) and not na(anchor)
        while array.size(boxes_arr) > 0
            box.delete(array.shift(boxes_arr))
        while array.size(labels_arr) > 0
            label.delete(array.shift(labels_arr))

        quarter_ms = math.floor(cycle_ms / 4.0)
        [current_cycle_start, _q] = f_cycle_math(time, anchor, cycle_ms)
        render_start = current_cycle_start - MAX_VISIBLE_CYCLES * cycle_ms

        cycle_start = render_start
        while cycle_start <= current_cycle_start + cycle_ms
            for q = 0 to 3
                q_start = cycle_start + q * quarter_ms
                q_end   = q_start + quarter_ms
                new_box = box.new(q_start, y_top, q_end, y_bot, xloc=xloc.bar_time, bgcolor=f_quarter_color(q), border_color=color.new(color.white, 50), border_width=1)
                array.push(boxes_arr, new_box)
                if show_labels
                    new_label = label.new(q_start + math.floor(quarter_ms / 2), (y_top + y_bot) / 2, text=label_prefix + "Q" + str.tostring(q + 1), xloc=xloc.bar_time, style=label.style_none, textcolor=color.white, size=f_label_size())
                    array.push(labels_arr, new_label)
            cycle_start := cycle_start + cycle_ms

// === ORCHESTRATION (Step 1: 90min cycle) ===
var array<box>   boxes_90m  = array.new<box>()
var array<label> labels_90m = array.new<label>()
f_render_cycle(CYCLE_90M_MS, 0.0, 1.0, min90_timeframes, "90M ", boxes_90m, labels_90m)

// Plot to maintain pane scale (invisible; boxes drive the visible y-range)
plot(0.5, "", color.new(color.white, 100), display=display.none)