//@version=6
indicator("Theorems Sessions Bottom Pane", "Sessions Timeline", overlay=false, max_boxes_count=500)

// === INPUTS ===
// Time settings
days_back = input.int(50, "Days Back", minval=1, maxval=200)
show_labels = input.bool(false, "Show Session Labels", group="Display")

// Session Times (in UTC)
// 90M Quarters
q1_start = input.string("00:00", "Q1 Start", group="90M Quarters")
q1_end = input.string("01:30", "Q1 End", group="90M Quarters")
q1_color = input.color(color.new(#2962ff, 30), "Q1 Color", group="90M Quarters")

q2_start = input.string("01:30", "Q2 Start", group="90M Quarters")
q2_end = input.string("03:00", "Q2 End", group="90M Quarters")
q2_color = input.color(color.new(#e91e63, 30), "Q2 Color", group="90M Quarters")

q3_start = input.string("03:00", "Q3 Start", group="90M Quarters")
q3_end = input.string("04:30", "Q3 End", group="90M Quarters")
q3_color = input.color(color.new(#00897b, 30), "Q3 Color", group="90M Quarters")

q4_start = input.string("04:30", "Q4 Start", group="90M Quarters")
q4_end = input.string("06:00", "Q4 End", group="90M Quarters")
q4_color = input.color(color.new(#ff6f00, 30), "Q4 Color", group="90M Quarters")

// Major Sessions
asia_start = input.string("00:00", "Asia Start", group="Major Sessions")
asia_end = input.string("09:00", "Asia End", group="Major Sessions")
asia_color = input.color(color.new(#ff9800, 40), "Asia Color", group="Major Sessions")

london_start = input.string("08:00", "London Start", group="Major Sessions")
london_end = input.string("16:30", "London End", group="Major Sessions")
london_color = input.color(color.new(#2196f3, 40), "London Color", group="Major Sessions")

ny_start = input.string("13:30", "New York Start", group="Major Sessions")
ny_end = input.string("22:00", "New York End", group="Major Sessions")
ny_color = input.color(color.new(#4caf50, 40), "New York Color", group="Major Sessions")

// === FUNCTIONS ===
// Parse time string to minutes since midnight
parseTimeToMinutes(timeStr) =>
    parts = str.split(timeStr, ":")
    if array.size(parts) == 2
        hours = str.tonumber(array.get(parts, 0))
        minutes = str.tonumber(array.get(parts, 1))
        int(hours * 60 + minutes)
    else
        0

// Convert timestamp to minutes since midnight
getMinutesSinceMidnight(t) =>
    hour(t) * 60 + minute(t)

// Check if current time is within session
isInSession(currentMinutes, startMinutes, endMinutes) =>
    if endMinutes > startMinutes
        currentMinutes >= startMinutes and currentMinutes < endMinutes
    else  // Session spans midnight
        currentMinutes >= startMinutes or currentMinutes < endMinutes

// === MAIN LOGIC ===
var box[] quarterBoxes = array.new<box>()
var box[] sessionBoxes = array.new<box>()

// Clear previous boxes
if barstate.isfirst
    for b in quarterBoxes
        box.delete(b)
    array.clear(quarterBoxes)

    for b in sessionBoxes
        box.delete(b)
    array.clear(sessionBoxes)

// Define vertical layers (0 = bottom)
LAYER_MAJOR_SESSIONS = 0
LAYER_90M_QUARTERS = 1

// Calculate bar width for boxes
bars_per_day = 1440 / timeframe.in_seconds(timeframe.period) * 60

// Parse session times
q1_start_min = parseTimeToMinutes(q1_start)
q1_end_min = parseTimeToMinutes(q1_end)
q2_start_min = parseTimeToMinutes(q2_start)
q2_end_min = parseTimeToMinutes(q2_end)
q3_start_min = parseTimeToMinutes(q3_start)
q3_end_min = parseTimeToMinutes(q3_end)
q4_start_min = parseTimeToMinutes(q4_start)
q4_end_min = parseTimeToMinutes(q4_end)

asia_start_min = parseTimeToMinutes(asia_start)
asia_end_min = parseTimeToMinutes(asia_end)
london_start_min = parseTimeToMinutes(london_start)
london_end_min = parseTimeToMinutes(london_end)
ny_start_min = parseTimeToMinutes(ny_start)
ny_end_min = parseTimeToMinutes(ny_end)

// Get current time info
current_minutes = getMinutesSinceMidnight(time)

// Determine colors for current bar based on sessions
q_color = color.new(color.gray, 90)
if isInSession(current_minutes, q1_start_min, q1_end_min)
    q_color := q1_color
else if isInSession(current_minutes, q2_start_min, q2_end_min)
    q_color := q2_color
else if isInSession(current_minutes, q3_start_min, q3_end_min)
    q_color := q3_color
else if isInSession(current_minutes, q4_start_min, q4_end_min)
    q_color := q4_color

session_color = color.new(color.gray, 95)
if isInSession(current_minutes, asia_start_min, asia_end_min)
    session_color := asia_color
if isInSession(current_minutes, london_start_min, london_end_min)
    session_color := london_color
if isInSession(current_minutes, ny_start_min, ny_end_min)
    session_color := ny_color

// Draw boxes for each bar
if barstate.isconfirmed or barstate.islast
    // Draw 90M Quarter box
    quarter_box = box.new(
        left=bar_index,
        top=60,
        right=bar_index + 1,
        bottom=40,
        bgcolor=q_color,
        border_color=color.new(color.gray, 80),
        border_width=0
    )
    array.push(quarterBoxes, quarter_box)

    // Draw Major Session box
    session_box = box.new(
        left=bar_index,
        top=35,
        right=bar_index + 1,
        bottom=15,
        bgcolor=session_color,
        border_color=color.new(color.gray, 80),
        border_width=0
    )
    array.push(sessionBoxes, session_box)

    // Maintain array size
    if array.size(quarterBoxes) > 500
        box.delete(array.shift(quarterBoxes))
    if array.size(sessionBoxes) > 500
        box.delete(array.shift(sessionBoxes))

// Create reference lines
hline(70, "Top", color=color.new(color.gray, 90), linestyle=hline.style_dotted)
hline(60, "Q Top", color=color.new(color.gray, 95), linestyle=hline.style_dotted)
hline(40, "Q Bottom", color=color.new(color.gray, 95), linestyle=hline.style_dotted)
hline(35, "S Top", color=color.new(color.gray, 95), linestyle=hline.style_dotted)
hline(15, "S Bottom", color=color.new(color.gray, 95), linestyle=hline.style_dotted)
hline(10, "Bottom", color=color.new(color.gray, 90), linestyle=hline.style_dotted)

// Add labels if enabled
if show_labels and barstate.islast
    label.new(bar_index + 5, 50, "90M Quarters", style=label.style_label_left, color=color.new(color.gray, 100), textcolor=color.gray, size=size.small)
    label.new(bar_index + 5, 25, "Major Sessions", style=label.style_label_left, color=color.new(color.gray, 100), textcolor=color.gray, size=size.small)

// Plot invisible line to maintain scale
plot(50, color=color.new(color.white, 100), display=display.none)