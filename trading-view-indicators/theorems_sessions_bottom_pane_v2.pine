//@version=6
indicator("Theorems Sessions Bottom Pane V2 - All Timeframes", "Sessions", overlay=false, max_boxes_count=500, max_labels_count=500)

// === CONFIGURATION ===
show_labels = input.bool(true, "Show Session Labels", group="Display")
label_size = input.string("small", "Label Size", options=["tiny", "small", "normal"], group="Display")

// Timeframe visibility settings (comma-separated list of timeframes)
year_timeframes = input.string("H4,H1", "Year Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,D1,W1,MN1")
month_timeframes = input.string("H4,H1,M45", "Month Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,D1,W1,MN1")
week_timeframes = input.string("H4,H1,M45", "Week Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,D1,W1,MN1")
day_timeframes = input.string("M45,M15,M1", "Day Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,D1,W1,MN1")
min90_timeframes = input.string("M15,M1", "90-Min Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,D1,W1,MN1")
min22_5_timeframes = input.string("M1", "22.5-Min Session Timeframes", group="Timeframe Visibility", tooltip="Comma-separated list: M1,M5,M15,M30,M45,H1,H4,D1,W1,MN1")

// Universal Quarter Colors
q1_color = input.color(color.new(color.gray, 80), "Quarter 1 Color", group="Colors")
q2_color = input.color(color.new(color.red, 80), "Quarter 2 Color", group="Colors")
q3_color = input.color(color.new(color.green, 80), "Quarter 3 Color", group="Colors")
q4_color = input.color(color.new(color.blue, 80), "Quarter 4 Color", group="Colors")

// Month Cycle Settings
month_start_dow = input.int(2, "Month Cycle Start DOW", minval=0, maxval=6, group="Month Cycle", tooltip="0=Sunday, 1=Monday, 2=Tuesday, 3=Wednesday, 4=Thursday, 5=Friday, 6=Saturday")
month_start_hour = input.int(0, "Month Cycle Start Hour", minval=0, maxval=23, group="Month Cycle")
month_start_minute = input.int(0, "Month Cycle Start Minute", minval=0, maxval=59, group="Month Cycle")

// Week Cycle Settings
week_start_dow = input.int(1, "Week Cycle Start DOW", minval=0, maxval=6, group="Week Cycle", tooltip="0=Sunday, 1=Monday, 2=Tuesday, 3=Wednesday, 4=Thursday, 5=Friday, 6=Saturday")
week_start_hour = input.int(0, "Week Cycle Start Hour", minval=0, maxval=23, group="Week Cycle")
week_start_minute = input.int(0, "Week Cycle Start Minute", minval=0, maxval=59, group="Week Cycle")

// === STATE VARIABLES ===
var int[] currentPeriods = array.new<int>(6, -1)  // [year, month, week, day, 90min, 22.5min]
var box[] currentBoxes = array.new<box>(6, na)    // [year, month, week, day, 90min, 22.5min]

// Session type indices
YEAR_SESSION = 0
MONTH_SESSION = 1
WEEK_SESSION = 2
DAY_SESSION = 3
MIN90_SESSION = 4
MIN22_5_SESSION = 5

// Arrays for managing multiple boxes and labels
var box[] allBoxes = array.new<box>()
var label[] allLabels = array.new<label>()

// === HELPER FUNCTIONS ===

getBorderColor() =>
    color.white

getTextColor() =>
    color.white

// === TIMEFRAME VISIBILITY FUNCTIONS ===

// Remove all spaces from a string
stripSpaces(str) =>
    result = ""
    for i = 0 to str.length(str) - 1
        char = str.substring(str, i, i + 1)
        if char != " "
            result := result + char
    result

// Get current timeframe as a string (M1, M5, H1, etc.)
getCurrentTimeframeString() =>
    tf = timeframe.period

    // Handle specific timeframes first
    if tf == "D"
        "D1"
    else if tf == "W"
        "W1"
    else if tf == "M"
        "MN1"
    else
        // Try to parse as number
        tfNum = str.tonumber(tf)
        if not na(tfNum)
            // Handle hour timeframes (60 = H1, 240 = H4, etc.)
            if tfNum >= 60
                hours = math.floor(tfNum / 60)
                "H" + str.tostring(hours)
            // Handle minute timeframes (1, 5, 15, 30, 45)
            else
                "M" + str.tostring(tfNum)
        else
            // Return as-is if can't parse
            tf

// Check if current timeframe is in the provided list
isTimeframeVisible(timeframeList) =>
    // Strip all spaces from the input
    cleanList = stripSpaces(timeframeList)
    currentTF = getCurrentTimeframeString()

    // Check if current timeframe is in the list
    str.contains(cleanList, currentTF)

// Get color for any quarter (unified)
getQuarterColor(quarterNum) =>
    // Use modulo 4 to cycle through colors for sessions with more than 4 quarters
    colorIndex = quarterNum % 4
    switch colorIndex
        0 => q1_color
        1 => q2_color
        2 => q3_color
        3 => q4_color
        => color.gray

// Get year label text
getYearLabel(quarterNum) =>
    "Y-Q" + str.tostring(quarterNum + 1)

// Get month label text
getMonthLabel(weekNum) =>
    "M-Q" + str.tostring(weekNum + 1)

// Get day label text
getDayLabel(quarterNum) =>
    "D-Q" + str.tostring(quarterNum + 1)

// Get 90-minute label text
get90MinLabel(segmentNum) =>
    // Cycle through Q1-Q4 for 90-minute segments
    quarterNum = segmentNum % 4
    "90M-Q" + str.tostring(quarterNum + 1)

// Get 22.5-minute label text
get22_5MinLabel(quarterNum) =>
    // Cycle through Q1-Q4 for 22.5-minute quarters
    quarterLabel = quarterNum % 4
    "22.5M-Q" + str.tostring(quarterLabel + 1)

// === MONTH CYCLE LOGIC ===

// Find the first occurrence of target DOW in the current or previous month
findMonthCycleStart(currentTime) =>
    // Get current date components
    y = year(currentTime)
    m = month(currentTime)
    d = dayofmonth(currentTime)

    // Find first occurrence of target DOW in current month
    firstOfMonth = timestamp(y, m, 1, month_start_hour, month_start_minute, 0)
    firstDow = dayofweek(firstOfMonth) - 1  // Convert to 0=Sunday format

    // Calculate days to add to get to target DOW
    daysToAdd = month_start_dow == firstDow ? 0 : (month_start_dow - firstDow + 7) % 7

    // First occurrence of target DOW in current month
    cycleStartThisMonth = firstOfMonth + (daysToAdd * 86400000)

    // If we're before the cycle start for this month, use previous month's cycle
    if currentTime < cycleStartThisMonth
        // Go to previous month
        prevM = m - 1
        prevY = y
        if prevM < 1
            prevM := 12
            prevY := y - 1

        firstOfPrevMonth = timestamp(prevY, prevM, 1, month_start_hour, month_start_minute, 0)
        firstDowPrev = dayofweek(firstOfPrevMonth) - 1
        daysToAddPrev = month_start_dow == firstDowPrev ? 0 : (month_start_dow - firstDowPrev + 7) % 7
        cycleStartPrevMonth = firstOfPrevMonth + (daysToAddPrev * 86400000)
        cycleStartPrevMonth
    else
        cycleStartThisMonth

// === WEEK CYCLE LOGIC ===

// Find the most recent occurrence of the configured week start day
findWeekCycleStart(currentTime) =>
    // Get current day of week (0=Sunday, 1=Monday, etc.)
    currentDow = dayofweek(currentTime) - 1

    // Calculate days back to the most recent start day
    daysBack = (currentDow - week_start_dow + 7) % 7

    // If we're on the start day but before the start time, go back to previous week
    if daysBack == 0
        currentHour = hour(currentTime)
        currentMinute = minute(currentTime)
        if currentHour < week_start_hour or (currentHour == week_start_hour and currentMinute < week_start_minute)
            daysBack := 7

    // Calculate the timestamp of the week cycle start
    msBack = daysBack * 86400000
    roughStart = currentTime - msBack

    // Adjust to exact start time
    timestamp(year(roughStart), month(roughStart), dayofmonth(roughStart),
              week_start_hour, week_start_minute, 0)

// === SESSION CONFIGURATION LAYER ===

// Create a session configuration
// Returns: [id, quarterDuration, maxQuarters, hasGaps, startOffset]
createSessionConfig(id, quarterDuration, maxQuarters, hasGaps, startOffset) =>
    config = array.new<float>(5)
    array.set(config, 0, id)
    array.set(config, 1, quarterDuration)
    array.set(config, 2, maxQuarters)
    array.set(config, 3, hasGaps ? 1 : 0)
    array.set(config, 4, startOffset)
    config

// Getters for clarity
getSessionId(config) => math.floor(array.get(config, 0))
getQuarterDuration(config) => array.get(config, 1)
getMaxQuarters(config) => math.floor(array.get(config, 2))
hasGaps(config) => array.get(config, 3) == 1
getStartOffset(config) => array.get(config, 4)

// === LAYER POSITIONING ===
layer_height = 30
base_y = 10

// Check visibility for each session type
year_visible = isTimeframeVisible(year_timeframes)
month_visible = isTimeframeVisible(month_timeframes)
week_visible = isTimeframeVisible(week_timeframes)
day_visible = isTimeframeVisible(day_timeframes)
min90_visible = isTimeframeVisible(min90_timeframes)
min22_5_visible = isTimeframeVisible(min22_5_timeframes)

// Calculate dynamic Y positions (stack visible layers with no gaps)
current_y = base_y

// Stack layers from bottom to top based on visibility
year_y = year_visible ? current_y : na
current_y := year_visible ? current_y + layer_height : current_y

month_y = month_visible ? current_y : na
current_y := month_visible ? current_y + layer_height : current_y

week_y = week_visible ? current_y : na
current_y := week_visible ? current_y + layer_height : current_y

day_y = day_visible ? current_y : na
current_y := day_visible ? current_y + layer_height : current_y

min90_y = min90_visible ? current_y : na
current_y := min90_visible ? current_y + layer_height : current_y

min22_5_y = min22_5_visible ? current_y : na
current_y := min22_5_visible ? current_y + layer_height : current_y

// Max Y position for scaling
max_y_position = current_y

// === DATA CALCULATION LAYER ===

// Calculate the reference start time for a session
calculateSessionStart(currentTime, sessionType) =>
    if sessionType == YEAR_SESSION
        // Year starts at Jan 1
        timestamp(year(currentTime), 1, 1, 0, 0, 0)
    else if sessionType == MONTH_SESSION
        // Month uses configured start day
        findMonthCycleStart(currentTime)
    else if sessionType == WEEK_SESSION
        // Week uses configured start day and time
        findWeekCycleStart(currentTime)
    else if sessionType == DAY_SESSION
        // Day starts at midnight
        timestamp(year(currentTime), month(currentTime), dayofmonth(currentTime), 0, 0, 0)
    else if sessionType == MIN90_SESSION
        // 90-minute cycles start at midnight
        timestamp(year(currentTime), month(currentTime), dayofmonth(currentTime), 0, 0, 0)
    else if sessionType == MIN22_5_SESSION
        // 22.5-minute cycles start at midnight
        timestamp(year(currentTime), month(currentTime), dayofmonth(currentTime), 0, 0, 0)
    else
        // Default to epoch
        timestamp(1970, 1, 1, 0, 0, 0)

// Calculate session data without any rendering
// Returns: [quarterIndex, isActive, shouldClearBox]
calculateSessionData(currentTime, config) =>
    sessionId = getSessionId(config)
    quarterDuration = getQuarterDuration(config)
    maxQuarters = getMaxQuarters(config)
    hasGaps = hasGaps(config)

    // Get start reference
    startTime = calculateSessionStart(currentTime, sessionId)

    // Calculate elapsed time
    timeElapsed = currentTime - startTime
    periodsElapsed = math.floor(timeElapsed / quarterDuration)

    // Determine if session is active
    isActive = not hasGaps or periodsElapsed < maxQuarters

    // Calculate quarter (0-3)
    quarterIndex = periodsElapsed % maxQuarters

    // Should clear box (for gaps)
    shouldClear = hasGaps and periodsElapsed >= maxQuarters

    result = array.new<int>(3)
    array.set(result, 0, quarterIndex)
    array.set(result, 1, isActive ? 1 : 0)
    array.set(result, 2, shouldClear ? 1 : 0)
    result

// === GENERIC SESSION HANDLER ===
handleSession(sessionType, newPeriod, layerY, sessionColor, labelPrefix, showLabel) =>
    // Get current state for this session type
    currentPeriod = array.get(currentPeriods, sessionType)
    currentBox = array.get(currentBoxes, sessionType)

    // Check if period changed
    if newPeriod != currentPeriod
        // Close previous box
        if not na(currentBox)
            box.set_right(currentBox, bar_index)

        // Create new box
        newBox = box.new(
            left=bar_index,
            top=layerY + layer_height,
            right=bar_index + 1,
            bottom=layerY,
            bgcolor=sessionColor,
            border_color=getBorderColor(),
            border_width=1,
            border_style=line.style_solid
        )
        array.push(allBoxes, newBox)

        // Add label if enabled
        if showLabel and show_labels
            lbl = label.new(
                x=bar_index,
                y=layerY + layer_height/2,
                text=labelPrefix + str.tostring(newPeriod + 1),
                style=label.style_label_left,
                color=color.new(color.black, 100),
                textcolor=getTextColor(),
                size=label_size == "tiny" ? size.tiny : label_size == "normal" ? size.normal : size.small
            )
            array.push(allLabels, lbl)

        // Update state
        array.set(currentPeriods, sessionType, newPeriod)
        array.set(currentBoxes, sessionType, newBox)
    else
        // Extend current box
        if not na(currentBox)
            box.set_right(currentBox, bar_index + 1)

// === RENDERING LAYER ===

// Render a session based on calculated data
renderSession(sessionType, quarterIndex, isActive, shouldClear, layerY, labelPrefix) =>
    if shouldClear
        // Clear box during gap period
        currentBox = array.get(currentBoxes, sessionType)
        if not na(currentBox)
            array.set(currentBoxes, sessionType, na)
    else if isActive

        // Draw the session using existing handler
        handleSession(
            sessionType,
            quarterIndex,
            layerY,
            getQuarterColor(quarterIndex),
            labelPrefix,
            show_labels
        )

// === SESSION PROCESSOR ===

// Process a session from config to render
processSessionDeclarative(currentTime, config, layerY, enabled, labelPrefix) =>
    if not enabled
        na
    else

        // Step 1: Calculate data
        sessionData = calculateSessionData(currentTime, config)
        quarterIndex = array.get(sessionData, 0)
        isActive = array.get(sessionData, 1) == 1
        shouldClear = array.get(sessionData, 2) == 1

        // Step 2: Render based on data
        sessionId = getSessionId(config)
        renderSession(sessionId, quarterIndex, isActive, shouldClear, layerY, labelPrefix)

// === SESSION CONFIGURATIONS ===

// Define all sessions declaratively
yearConfig = createSessionConfig(
    YEAR_SESSION,
    7889400000,  // ~3 months (91.25 days) per quarter
    4,           // 4 quarters
    false,       // no gaps
    0            // start offset
)

monthConfig = createSessionConfig(
    MONTH_SESSION,
    604800000,   // 1 week (7 days) per quarter
    4,           // 4 quarters
    true,        // has gaps after week 4
    0            // uses custom start calculation
)

weekConfig = createSessionConfig(
    WEEK_SESSION,
    86400000,    // 1 day (24 hours) per quarter
    4,           // 4 quarters (4 days)
    true,        // has gaps after day 4
    0            // uses custom week cycle start calculation
)

dayConfig = createSessionConfig(
    DAY_SESSION,
    21600000,    // 6 hours per quarter
    4,           // 4 quarters (00:00-06:00, 06:00-12:00, 12:00-18:00, 18:00-00:00)
    false,       // no gaps - continuous
    0            // starts at midnight
)

min90Config = createSessionConfig(
    MIN90_SESSION,
    5400000,     // 90 minutes per segment
    4,           // 4 quarters cycling (Q1-Q4 repeating)
    false,       // no gaps - continuous
    0            // starts at midnight
)

min22_5Config = createSessionConfig(
    MIN22_5_SESSION,
    1350000,     // 22.5 minutes per quarter
    4,           // 4 quarters cycling (Q1-Q4 repeating)
    false,       // no gaps - continuous
    0            // starts at midnight
)

// === MAIN LOGIC ===

currentTime = time

// Process each session through the declarative pipeline (only if visible)
if year_visible
    processSessionDeclarative(currentTime, yearConfig, year_y, true, "Y-Q")

if month_visible
    processSessionDeclarative(currentTime, monthConfig, month_y, true, "M-Q")

if week_visible
    processSessionDeclarative(currentTime, weekConfig, week_y, true, "W-Q")

if day_visible
    processSessionDeclarative(currentTime, dayConfig, day_y, true, "D-Q")

if min90_visible
    processSessionDeclarative(currentTime, min90Config, min90_y, true, "90M-Q")

if min22_5_visible
    processSessionDeclarative(currentTime, min22_5Config, min22_5_y, true, "22.5M-Q")

// === CLEANUP ===
while array.size(allBoxes) > 500
    oldBox = array.shift(allBoxes)
    if not na(oldBox)
        box.delete(oldBox)

while array.size(allLabels) > 500
    oldLabel = array.shift(allLabels)
    if not na(oldLabel)
        label.delete(oldLabel)

// === VISUAL GUIDES ===
// Since hlines require constants, we'll skip them for dynamic layouts
// The boxes themselves provide sufficient visual boundaries

// Plot to maintain scale (use calculated max_y_position)
plot(max_y_position/2, "", color.new(color.white, 100), display=display.none)