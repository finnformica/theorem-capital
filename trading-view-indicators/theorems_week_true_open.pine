//@version=6
indicator("Theorems Week True Open", overlay=true, max_lines_count=200)

// === INPUTS ===
// Timeframe filter
show_m1 = input.bool(false, "Show M1")
show_m5 = input.bool(true, "Show M5")
show_m15 = input.bool(true, "Show M15")
show_m30 = input.bool(false, "Show M30")
show_h1 = input.bool(true, "Show H1")
show_h4 = input.bool(false, "Show H4")
show_d1 = input.bool(false, "Show D1")
show_w1 = input.bool(true, "Show W1")
show_mn1 = input.bool(false, "Show MN1")

// Week settings
week_enable = input.bool(true, "Week Enable")
week_day_of_week = input.string("Monday", "Day of Week",
    options=["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"])
week_hour = input.int(8, "Hour", tooltip="Hour in 24-hour format", minval=0, maxval=23)
week_minute = input.int(0, "Minute", minval=0, maxval=59)

// Line display settings
week_full_day = input.bool(false, "Full Day", tooltip="Draw line for entire day")
week_length_minutes = input.int(120, "Length Minutes", tooltip="Line length in minutes (if not full day)", minval=1)
week_color = input.color(color.yellow, "Week Line Color")
week_width = input.int(2, "Week Line Width", minval=1, maxval=5)
week_style = input.string("Dashed", "Week Line Style", options=["Solid", "Dashed", "Dotted"])

// Time mode
use_server_time = input.bool(true, "Use Server Time", tooltip="Use server time vs local time")
weeks_back = input.int(20, "Weeks Back", tooltip="How many past weeks to draw", minval=1, maxval=100)

// === HELPER FUNCTIONS ===
// Check if current timeframe is allowed
is_tf_allowed() =>
    current_tf = timeframe.period
    if current_tf == "1"
        show_m1
    else if current_tf == "5"
        show_m5
    else if current_tf == "15"
        show_m15
    else if current_tf == "30"
        show_m30
    else if current_tf == "60"
        show_h1
    else if current_tf == "240"
        show_h4
    else if current_tf == "D" or current_tf == "1D"
        show_d1
    else if current_tf == "W" or current_tf == "1W"
        show_w1
    else if current_tf == "M" or current_tf == "1M"
        show_mn1
    else
        true

// Convert day of week string to number (1=Monday, 0=Sunday)
day_of_week_to_number(dow_str) =>
    switch dow_str
        "Sunday" => 0
        "Monday" => 1
        "Tuesday" => 2
        "Wednesday" => 3
        "Thursday" => 4
        "Friday" => 5
        "Saturday" => 6
        => 1  // Default to Monday

// Get week start (Monday 00:00)
week_start_monday(t) =>
    days_to_monday = dayofweek(t) - 2  // 2 = Monday in Pine Script (1-indexed)
    if days_to_monday < 0
        days_to_monday += 7

    // Get start of day
    day_start = math.floor(t / 86400000) * 86400000
    day_start - days_to_monday * 86400000

// Get the actual date of the selected weekday in that week
get_weekday_date(week_start_monday, weekday) =>
    if weekday == 0  // Sunday
        week_start_monday - 86400000  // Day before Monday
    else
        week_start_monday + (weekday - 1) * 86400000

// Build target datetime
build_target_datetime(day_date, hh, mm) =>
    day_timestamp = math.floor(day_date / 86400000) * 86400000
    day_timestamp + hh * 3600000 + mm * 60000

// Apply time mode (server vs local)
apply_time_mode(server_time) =>
    if use_server_time
        server_time
    else
        // Approximate local time adjustment (Pine Script doesn't have exact local time)
        server_time  // Simplified - in practice would need timezone adjustment

// Get open price at target time (simplified)
get_open_at_target(target_time) =>
    // In Pine Script, we approximate by using the open price of the current timeframe
    // This is a limitation compared to MT4's ability to check exact bar times
    current_time = time
    time_diff = math.abs(current_time - target_time)

    // If within reasonable range, use current open
    if time_diff < 86400000  // Within 1 day
        open
    else
        na

// Convert line style string to Pine Script constant
get_line_style() =>
    switch week_style
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

// === MAIN LOGIC ===
var line[] week_lines = array.new<line>()

if week_enable and is_tf_allowed() and barstate.islast
    // Clean up old lines
    for i = 0 to array.size(week_lines) - 1
        line.delete(array.get(week_lines, i))
    array.clear(week_lines)

    current_time = time
    target_weekday = day_of_week_to_number(week_day_of_week)
    week_start_monday_current = week_start_monday(current_time)

    // Draw lines for specified number of weeks back
    for i = 0 to weeks_back - 1
        // Calculate week start for i weeks ago
        ws = week_start_monday_current - i * 7 * 86400000

        // Get the target date for the specified weekday
        target_date = get_weekday_date(ws, target_weekday)

        // Build the target server time
        target_server_time = build_target_datetime(target_date, week_hour, week_minute)

        // Calculate end time
        length_minutes = week_full_day ? 1440 : week_length_minutes  // 1440 = full day
        end_server_time = target_server_time + length_minutes * 60000

        // Apply time mode
        display_start = apply_time_mode(target_server_time)
        display_end = apply_time_mode(end_server_time)

        // Get price level
        price_level = get_open_at_target(target_server_time)

        if not na(price_level)
            // Convert timestamps to bar indices
            // Find the bar closest to the display start time
            start_bar_index = bar_index
            for j = 0 to math.min(bar_index, 200)
                if math.abs(time[j] - display_start) < math.abs(time[start_bar_index - bar_index] - display_start)
                    start_bar_index := bar_index - j

            // Calculate end bar index based on duration
            duration_bars = math.max(1, math.round((display_end - display_start) / (timeframe.in_seconds(timeframe.period) * 1000)))
            end_bar_index = start_bar_index + duration_bars

            // Create horizontal line segment
            week_line = line.new(
                x1=start_bar_index,
                y1=price_level,
                x2=end_bar_index,
                y2=price_level,
                color=week_color,
                width=week_width,
                style=get_line_style()
            )
            array.push(week_lines, week_line)

// Display current settings and timeframe status
if barstate.islast
    tf_status = is_tf_allowed() ? "✓ Allowed" : "✗ Not Allowed"
    current_tf_str = timeframe.period

    debug_text = "Week True Open\n" +
                 "TF: " + current_tf_str + " " + tf_status + "\n" +
                 "Day: " + week_day_of_week + "\n" +
                 "Time: " + str.format("{0,number,00}:{1,number,00}", week_hour, week_minute) + "\n" +
                 "Mode: " + (use_server_time ? "Server" : "Local")

    debug_color = is_tf_allowed() ? color.new(week_color, 80) : color.new(color.red, 80)
    text_color = is_tf_allowed() ? color.white : color.yellow

    label.new(
        x=bar_index - 100,
        y=high,
        text=debug_text,
        color=debug_color,
        textcolor=text_color,
        style=label.style_label_down,
        size=size.small
    )

// Plot invisible line to ensure indicator runs
plot(na, title="Week True Open")

// === NOTES ===
// This Pine Script version adapts the MT4 Week True Open indicator for TradingView
//
// Key features:
// 1. Draws horizontal lines at specific weekly cycle times
// 2. Configurable day of week and time within that day
// 3. Timeframe filtering to show/hide on specific chart periods
// 4. Support for full day or timed duration lines
// 5. Historical line drawing for specified number of weeks back
//
// Differences from MT4 version:
// 1. Simplified time zone handling (Pine Script limitation)
// 2. Approximate price level calculation (uses current open)
// 3. Cannot access exact historical bar data at specific times
// 4. Timeframe detection based on Pine Script's timeframe.period
//
// The indicator helps identify weekly cycle opening times which are
// important in institutional trading analysis, particularly for
// weekly true range and directional bias establishment.
//
// Timeframe filtering allows traders to show the lines only on
// relevant chart periods for better visual clarity.